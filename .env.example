# Ovnivers Configuration
# Copy this to .env and fill in your values

# TMDB API Key (required for catalog and metadata)
TMDB_KEY=your_tmdb_api_key_here

# Server port (default: 3000)
PORT=3000

# Public URL (set automatically on Render via RENDER_EXTERNAL_URL)
# BASE_URL=https://your-addon.onrender.com

# ─── Anti-bot bypass ─────────────────────────────
# Scrapeless Universal Scraping API — bypasses Cloudflare Turnstile + JS rendering
# Free trial: https://app.scrapeless.com (500 free requests)
# Docs: https://docs.scrapeless.com/en/universal-scraping-api/
SCRAPELESS_API_KEY=

# Cloudflare Worker smart proxy — bypasses IP blocks and maintains cookie jars
# Deploy with: npx wrangler deploy cloudflare-worker/proxy-worker.js
# PROXY_URL=https://ovnivers-proxy.<your-subdomain>.workers.dev
