# Ovnivers Configuration
# Copy this to .env and fill in your values

# TMDB API Key (required for catalog and metadata)
TMDB_KEY=your_tmdb_api_key_here

# Server port (default: 3000)
PORT=3000

# Public URL (set automatically on Render via RENDER_EXTERNAL_URL)
# BASE_URL=https://your-addon.onrender.com

# Pigamer37 anime proxy base URL (optional)
# PIGAMER_BASE=https://pigamer37.alwaysdata.net
